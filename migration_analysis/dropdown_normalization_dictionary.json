{
  "meta": {
    "source": "scripts/post-pilot-loans.js",
    "scope": "Loan migration normalizations currently implemented",
    "notes": [
      "Only mappings present in importer are listed.",
      "Blank or missing legacy values remain blank unless fallback is defined."
    ]
  },
  "dropdowns": {
    "bankName": {
      "HDFC*": "HDFC Bank",
      "ICICI*": "ICICI Bank",
      "AXIS*": "Axis Bank",
      "SBI/STATE BANK*": "State Bank of India",
      "YESBANK/YES BANK*": "Yes Bank"
    },
    "receivedAs": {
      "ORIGINAL": "Original",
      "PHOTOCOPY/PHOTO COPY/PHOTOCOPY.": "Photocopy"
    },
    "emiPlan": {
      "1+1/1PLUS1": "1+1",
      "NORMAL": "Normal"
    },
    "purposeOfLoan_cashIn_refinance_only": {
      "personal": "Other",
      "business": "Business",
      "travel": "Travel",
      "education": "Education",
      "marriage": "Marriage",
      "agriculture": "Agriculture",
      "*": "Other"
    },
    "occupationType": {
      "*contains salaried*": "Salaried",
      "*contains professional*": "Self Employed Professional",
      "*other non-empty*": "Self Employed"
    },
    "applicantType": {
      "HIRE_TYPE=company + companyType!=Proprietorship": "Company",
      "*otherwise*": "Individual"
    },
    "gender": {
      "M/MALE": "Male",
      "F/FEMALE": "Female"
    },
    "maritalStatus": {
      "M/MARRIED": "Married",
      "U/S/SINGLE/UNMARRIED": "Unmarried"
    },
    "education": {
      "*contains post*": "Postgraduate",
      "*contains graduate*": "Graduate",
      "*contains under*": "Undergraduate",
      "*other non-empty*": "Others"
    },
    "houseType": {
      "*contains rent*": "Rented",
      "*contains parent*": "Parental",
      "*contains company*": "Company Provided",
      "*otherwise*": "Owned"
    },
    "insuranceBy": {
      "*contains mnfg or dealer*": "Showroom",
      "*contains autocredit*": "Autocredits India LLP",
      "*contains customer*": "Customer",
      "*contains broker*": "Broker"
    },
    "yesNo": {
      "Y/YES": "Yes",
      "N/NO": "No"
    },
    "companyType": {
      "*contains PROPRIETOR*": "Proprietorship",
      "*contains PARTNER/LLP/PARTNERSHIP*": "Partnership",
      "*contains PVT/PRIVATE*": "Pvt Ltd",
      "*contains LIMITED/LTD*": "Ltd",
      "fallback": "Legacy text"
    },
    "companyType_inference_priority": {
      "CATEGORY contains PARTNER": "Partnership",
      "name contains PVT LTD/PRIVATE LIMITED": "Pvt Ltd",
      "name contains LIMITED/LTD": "Ltd",
      "name contains LLP/PARTNERSHIP": "Partnership",
      "name contains PROPRIETOR/PROP": "Proprietorship",
      "PAN 4th letter C": "Pvt Ltd",
      "PAN 4th letter F": "Partnership",
      "PAN 4th letter P": "Proprietorship",
      "PAN 4th letter T": "Trust",
      "fallback": "CATEGORY/ORGANISATION_TYPE"
    },
    "instrumentSignedBy": {
      "*contains grntr/guarantor*": "Guarantor",
      "*contains co*": "Co-applicant",
      "*otherwise*": "Applicant"
    }
  },
  "vehicle_normalization": {
    "variant_trim": [
      "remove make prefix from variant",
      "remove model prefix from variant"
    ],
    "fallback_vehicle_text_sources": [
      "RC_CUSTOMER_ACCOUNT.MAKE_MODEL",
      "RC_CUSTOMER_ACCOUNT.DELIVERED_MAKE_MODEL",
      "CPV_DETAIL.CAR_MODEL"
    ],
    "logic": [
      "try exact brand+model+variant text match against vehicle master",
      "else score partial matches by brand/model/variant substrings",
      "pick highest scored vehicle"
    ]
  },
  "fallbacks_recently_added": {
    "dispatchDate": [
      "RC_DOC_DESPATCH_MASTER.DATE_OF_DESP",
      "RC_CUSTOMER_ACCOUNT.DATE_OF_FILE_DESPATCH",
      "RC_CUSTOMER_ACCOUNT.DATE_WHEN_FILE_DESPATCH"
    ],
    "primaryMobileAlt": [
      "CPV_DETAIL.RESI_PHONE2",
      "CPV_DETAIL.RESI_PHONE3",
      "CPV_DETAIL.OFF_PHONE2",
      "CPV_DETAIL.OFF_PHONE3",
      "GURANTOR.RESI_PHONE",
      "GURANTOR.OFF_PHONE",
      "CPV_DETAIL.OFF_PHONE1"
    ],
    "officePhone": [
      "CPV_DETAIL.OFF_PHONE1",
      "CPV_DETAIL.OFF_PHONE2",
      "CPV_DETAIL.OFF_PHONE3",
      "GURANTOR.OFF_PHONE",
      "RC_CUSTOMER_ACCOUNT.PHONE_NUMBERS_OFFICE",
      "AUTH_SIGNATORY.PHONE/AUTH_SIGNATORY.MOBILE",
      "CPV_DETAIL.RESI_PHONE1"
    ],
    "company_coApplicant_fallback_from_gurantor": {
      "name": "GURANTOR.NAME",
      "primaryMobile": "GURANTOR.RESI_PHONE/GURANTOR.OFF_PHONE",
      "aadhaar": "GURANTOR.G_AADHAAR_NUMBER",
      "dependents": "GURANTOR.NO_OF_DEPEND",
      "address": "GURANTOR.RESI_ADD1+RESI_ADD2 or OFF_ADD1+OFF_ADD2",
      "pincode_city": "GURANTOR.RESI_PIN/RESI_CITY or OFF_PIN/OFF_CITY"
    },
    "migration_policy": {
      "guarantor_handling": "Guarantor is treated as co-applicant fallback in migration",
      "hasGuarantor": false
    }
  }
}
